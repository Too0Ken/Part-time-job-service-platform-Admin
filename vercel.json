{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/:path*"
    },
    {
      "source": "/admin/admin",
      "destination": "/index.html"
    },
    {
      "source": "/admin/admin/:path*",
      "destination": "/:path*"
    }
  ]
}
